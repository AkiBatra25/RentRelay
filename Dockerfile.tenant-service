FROM golang:1.26-alpine AS builder

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN go build -buildvcs=false -o /out/tenant-service ./cmd/tenant-service

FROM alpine:3.20

WORKDIR /app

COPY --from=builder /out/tenant-service /app/tenant-service

EXPOSE 50054

CMD ["/app/tenant-service"]
