FROM golang:1.26-alpine AS builder

WORKDIR /app

COPY go.mod go.sum ./
RUN go mod download

COPY . .
RUN go build -buildvcs=false -o /out/landlord-service ./cmd/landlord-service

FROM alpine:3.20

WORKDIR /app

COPY --from=builder /out/landlord-service /app/landlord-service

EXPOSE 50053

CMD ["/app/landlord-service"]
